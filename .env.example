# ==========================================
# ENTERPRISE DMS/SFA PLATFORM CONFIGURATION
# ==========================================

# 1. DATABASE CONFIGURATION (POSTGRESQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=dms
DB_SSL=false
DB_TIMEOUT=30000

# 2. MESSAGE BROKER CONFIGURATION (RABBITMQ)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=

# 3. CACHE CONFIGURATION (REDIS)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. SECRET STORE CONFIGURATION (HASHICORP VAULT)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret

# 5. UPSTREAM SERVICE URLS
CONFIG_SERVICE_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
GATEWAY_URL=http://localhost:3000

# 6. SECURITY CONFIGURATION
JWT_ISSUER=dms-identity-service
JWT_AUDIENCE=dms-enterprise
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=10

# 7. LOGGING
LOG_LEVEL=DEBUG

# 8. MOCK DATA SEED CONFIGURATION
SEED_MOCK_DATA=true
SEED_TENANT_ID=tenant-uuid-1111
SEED_AGENT_ID=agent-uuid-2222
SEED_OUTLET_LAT=28.6139
SEED_OUTLET_LNG=77.2090
