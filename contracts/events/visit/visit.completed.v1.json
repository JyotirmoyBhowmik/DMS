{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dms.enterprise/events/visit/visit.completed.v1",
  "title": "VisitCompletedV1",
  "description": "Emitted when a sales agent completes a retail outlet visit.",
  "type": "object",
  "required": [
    "visitId",
    "agentId",
    "outletId",
    "checkInAt",
    "checkOutAt",
    "location",
    "activities",
    "completedAt"
  ],
  "properties": {
    "visitId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this visit."
    },
    "agentId": {
      "type": "string",
      "format": "uuid",
      "description": "Sales agent who performed the visit."
    },
    "outletId": {
      "type": "string",
      "format": "uuid",
      "description": "Retail outlet visited."
    },
    "journeyPlanId": {
      "type": "string",
      "format": "uuid",
      "description": "Journey plan this visit belongs to, if applicable."
    },
    "checkInAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the agent checked in."
    },
    "checkOutAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the agent checked out."
    },
    "durationMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Duration of the visit in minutes."
    },
    "location": {
      "type": "object",
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "accuracy": {
          "type": "number",
          "minimum": 0,
          "description": "GPS accuracy in meters."
        }
      },
      "additionalProperties": false,
      "description": "GPS coordinates at check-in."
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "description": "Activities performed during the visit.",
      "items": {
        "type": "string",
        "enum": [
          "ORDER_TAKEN",
          "PAYMENT_COLLECTED",
          "MERCHANDISING",
          "STOCK_CHECK",
          "COMPLAINT_LOGGED",
          "SCHEME_COMMUNICATED",
          "RETURN_PROCESSED",
          "NO_ORDER"
        ]
      }
    },
    "orderIds": {
      "type": "array",
      "description": "Orders placed during the visit.",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "photoUrls": {
      "type": "array",
      "description": "URLs of photos taken during the visit.",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Agent notes about the visit."
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the visit was marked complete."
    }
  },
  "additionalProperties": false
}
