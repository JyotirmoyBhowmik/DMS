{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dms.enterprise/events/config/tenant.config.updated.v1",
  "title": "TenantConfigUpdatedV1",
  "description": "Emitted when a tenant's configuration is updated.",
  "type": "object",
  "required": [
    "tenantId",
    "configKey",
    "oldValue",
    "newValue",
    "updatedBy",
    "updatedAt"
  ],
  "properties": {
    "tenantId": {
      "type": "string",
      "format": "uuid",
      "description": "Tenant whose configuration was updated."
    },
    "configKey": {
      "type": "string",
      "description": "Configuration key that was changed."
    },
    "namespace": {
      "type": "string",
      "description": "Configuration namespace (e.g. 'sync', 'order', 'notification')."
    },
    "oldValue": {
      "description": "Previous configuration value."
    },
    "newValue": {
      "description": "New configuration value."
    },
    "valueType": {
      "type": "string",
      "enum": ["STRING", "INTEGER", "BOOLEAN", "JSON", "DURATION"],
      "description": "Data type of the configuration value."
    },
    "reason": {
      "type": "string",
      "maxLength": 500,
      "description": "Reason for the configuration change."
    },
    "updatedBy": {
      "type": "string",
      "format": "uuid",
      "description": "User who updated the configuration."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the update."
    }
  },
  "additionalProperties": false
}
