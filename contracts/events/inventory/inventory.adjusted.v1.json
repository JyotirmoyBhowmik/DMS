{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dms.enterprise/events/inventory/inventory.adjusted.v1",
  "title": "InventoryAdjustedV1",
  "description": "Emitted when warehouse inventory is adjusted (receipt, dispatch, damage, return, correction).",
  "type": "object",
  "required": [
    "adjustmentId",
    "distributorId",
    "warehouseId",
    "sku",
    "adjustmentType",
    "quantityBefore",
    "quantityChange",
    "quantityAfter",
    "reason",
    "adjustedBy",
    "adjustedAt"
  ],
  "properties": {
    "adjustmentId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this adjustment."
    },
    "distributorId": {
      "type": "string",
      "format": "uuid",
      "description": "Distributor whose inventory was adjusted."
    },
    "warehouseId": {
      "type": "string",
      "format": "uuid",
      "description": "Warehouse where the adjustment occurred."
    },
    "sku": {
      "type": "string",
      "description": "Stock-keeping unit identifier."
    },
    "batchNumber": {
      "type": "string",
      "description": "Batch or lot number, if applicable."
    },
    "adjustmentType": {
      "type": "string",
      "enum": ["RECEIPT", "DISPATCH", "DAMAGE", "RETURN", "EXPIRY", "CORRECTION", "TRANSFER"],
      "description": "Category of the inventory adjustment."
    },
    "quantityBefore": {
      "type": "integer",
      "minimum": 0,
      "description": "Stock quantity before adjustment."
    },
    "quantityChange": {
      "type": "integer",
      "description": "Signed quantity change (positive for additions, negative for removals)."
    },
    "quantityAfter": {
      "type": "integer",
      "minimum": 0,
      "description": "Stock quantity after adjustment."
    },
    "reason": {
      "type": "string",
      "maxLength": 500,
      "description": "Reason or reference for the adjustment."
    },
    "referenceId": {
      "type": "string",
      "description": "Related entity ID (e.g. orderId, returnId, transferId)."
    },
    "adjustedBy": {
      "type": "string",
      "format": "uuid",
      "description": "User who performed the adjustment."
    },
    "adjustedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the adjustment."
    }
  },
  "additionalProperties": false
}
