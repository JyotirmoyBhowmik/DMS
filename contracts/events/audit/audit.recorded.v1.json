{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dms.enterprise/events/audit/audit.recorded.v1",
  "title": "AuditRecordedV1",
  "description": "Emitted when an auditable action is recorded in the immutable audit log.",
  "type": "object",
  "required": [
    "auditId",
    "tenantId",
    "actorId",
    "actorType",
    "action",
    "resourceType",
    "resourceId",
    "outcome",
    "timestamp",
    "chainHash"
  ],
  "properties": {
    "auditId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique audit record identifier."
    },
    "tenantId": {
      "type": "string",
      "format": "uuid",
      "description": "Tenant context."
    },
    "actorId": {
      "type": "string",
      "format": "uuid",
      "description": "User or service that performed the action."
    },
    "actorType": {
      "type": "string",
      "enum": ["USER", "SERVICE", "SYSTEM"],
      "description": "Type of actor."
    },
    "action": {
      "type": "string",
      "description": "Action performed (e.g. order:create, user:delete, config:update)."
    },
    "resourceType": {
      "type": "string",
      "description": "Type of resource acted upon (e.g. Order, User, Distributor)."
    },
    "resourceId": {
      "type": "string",
      "description": "Identifier of the resource."
    },
    "changes": {
      "type": "array",
      "description": "Field-level changes for update actions.",
      "items": {
        "type": "object",
        "required": ["field", "newValue"],
        "properties": {
          "field": {
            "type": "string",
            "description": "Field name that changed."
          },
          "oldValue": {
            "description": "Previous value."
          },
          "newValue": {
            "description": "New value."
          }
        },
        "additionalProperties": false
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["SUCCESS", "FAILURE", "DENIED"],
      "description": "Outcome of the action."
    },
    "sourceIp": {
      "type": "string",
      "description": "IP address of the request origin."
    },
    "userAgent": {
      "type": "string",
      "description": "User-Agent header of the client."
    },
    "correlationId": {
      "type": "string",
      "description": "Distributed tracing correlation ID."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the audited action."
    },
    "chainHash": {
      "type": "string",
      "description": "SHA-256 hash linking this record to the previous one in the tamper-evident chain."
    }
  },
  "additionalProperties": false
}
