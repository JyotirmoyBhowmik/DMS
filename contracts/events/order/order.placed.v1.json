{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dms.enterprise/events/order/order.placed.v1",
  "title": "OrderPlacedV1",
  "description": "Emitted when a sales agent places a new order from the field.",
  "type": "object",
  "required": [
    "orderId",
    "distributorId",
    "outletId",
    "agentId",
    "lines",
    "schemeIds",
    "netAmount",
    "placedAt",
    "idempotencyKey"
  ],
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the order."
    },
    "distributorId": {
      "type": "string",
      "format": "uuid",
      "description": "Distributor servicing this order."
    },
    "outletId": {
      "type": "string",
      "format": "uuid",
      "description": "Retail outlet placing the order."
    },
    "agentId": {
      "type": "string",
      "format": "uuid",
      "description": "Sales agent who captured the order."
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "description": "Order line items.",
      "items": {
        "type": "object",
        "required": ["sku", "qty", "unitPrice", "discount"],
        "properties": {
          "sku": {
            "type": "string",
            "description": "Stock-keeping unit identifier."
          },
          "qty": {
            "type": "integer",
            "minimum": 1,
            "description": "Quantity ordered."
          },
          "unitPrice": {
            "type": "number",
            "minimum": 0,
            "description": "Price per unit before discount."
          },
          "discount": {
            "type": "number",
            "minimum": 0,
            "description": "Discount amount applied to this line."
          }
        },
        "additionalProperties": false
      }
    },
    "schemeIds": {
      "type": "array",
      "description": "Promotional scheme identifiers applied to the order.",
      "items": {
        "type": "string"
      }
    },
    "netAmount": {
      "type": "number",
      "minimum": 0,
      "description": "Net order amount after discounts."
    },
    "placedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the order was placed."
    },
    "idempotencyKey": {
      "type": "string",
      "description": "Client-generated key for exactly-once processing."
    }
  },
  "additionalProperties": false
}
